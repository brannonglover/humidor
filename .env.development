# Local development: use local API server instead of production.
# Empty = config.js uses localhost (simulator) or 10.0.2.2 (Android emulator).
# For physical device on same network, create .env.development.local with:
#   EXPO_PUBLIC_API_URL=http://YOUR_MACHINE_IP:5001
#   REACT_NATIVE_PACKAGER_HOSTNAME=YOUR_MACHINE_IP  (if npm run ios:device auto-detect fails)
EXPO_PUBLIC_API_URL=http://192.168.1.94:5001
